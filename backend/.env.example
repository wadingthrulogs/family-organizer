# ── Required ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Public-facing URL (used for OAuth callbacks and session cookies).
# Set to the IP/hostname family members use to reach the app.
# Examples:
#   https://192.168.1.50:4173                       ← LAN IP with self-signed cert
#   https://familyorganizer.tail411eff.ts.net:4173  ← Tailscale MagicDNS (recommended)
#   https://family.example.com                      ← public domain
APP_BASE_URL=https://localhost:4173

# Set to true when the app is served over HTTPS (required for secure session cookies
# and browser push notifications). Must be false only on plain HTTP.
SESSION_SECURE=true

# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Timezone for the server (e.g. America/Los_Angeles, America/New_York, UTC)
TZ=UTC

# ── Optional: Google Calendar ─────────────────────────────────────────────────
# Create a Google Cloud project and OAuth 2.0 credentials.
# See docs/deployment.md → "Google Calendar Integration" for step-by-step guide.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URL=http://localhost:4173/api/v1/integrations/google/callback

# ── Optional: Email notifications (SMTP) ─────────────────────────────────────
# For Gmail use an App Password (requires 2FA): myaccount.google.com → Security → App passwords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Family Organizer <you@gmail.com>

# ── Optional: Browser push notifications (VAPID) ─────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# PUSH_VAPID_PUBLIC_KEY=
# PUSH_VAPID_PRIVATE_KEY=

# ── Optional: Weather widget ──────────────────────────────────────────────────
# Get a free API key at https://openweathermap.org/api
# Also set weatherLocation in Settings → Household (city name or "lat,lon")
# OPENWEATHER_API_KEY=
