generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  email        String?       @unique
  passwordHash String
  pinHash      String?
  role         String        @default("MEMBER")
  authProvider String        @default("local")
  timezone     String        @default("UTC")
  colorHex     String?
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  userSecrets        UserSecret[]
  linkedCalendars    LinkedCalendar[]
  authoredTasks      Task[]             @relation("TaskAuthor")
  taskAssignments    TaskAssignment[]
  ownedGroceryLists  GroceryList[]      @relation("GroceryOwner")
  groceryItems       GroceryItem[]      @relation("GroceryAssignee")
  groceryClaims      GroceryItem[]      @relation("GroceryClaimer")
  reminders          Reminder[]
  choreAssignments   ChoreAssignment[]  @relation("ChoreAssignee")
  choreVerifications ChoreAssignment[]  @relation("ChoreVerifier")
  attachments        Attachment[]
  auditLogs          AuditLog[]
  pushSubscriptions  PushSubscription[]
  notificationLogs   NotificationLog[]
  taskStatusChanges  TaskStatusChange[] @relation("TaskStatusChanger")
  preference         UserPreference?
  googleAccounts     GoogleAccount[]
  recipes            Recipe[]           @relation("RecipeAuthor")
  mealPlans          MealPlan[]         @relation("MealPlanAuthor")
}

model UserPreference {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  theme           String   @default("default")
  dashboardConfig String?
  hiddenTabs      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSecret {
  id             Int      @id @default(autoincrement())
  userId         Int
  secretType     String
  encryptedValue Bytes
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, secretType])
}

model GoogleAccount {
  id                    Int      @id @default(autoincrement())
  userId                Int
  email                 String
  displayName           String?
  encryptedRefreshToken Bytes
  lastSyncedAt          DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedCalendars  LinkedCalendar[]

  @@unique([userId, email])
}

model LinkedCalendar {
  id              Int      @id @default(autoincrement())
  userId          Int
  googleAccountId Int?
  googleId        String
  displayName     String
  colorHex        String?
  accessRole      String
  syncToken       String?
  lastSyncedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  googleAccount  GoogleAccount?  @relation(fields: [googleAccountId], references: [id], onDelete: SetNull)
  events         FamilyEvent[]

  @@unique([userId, googleId])
}

model FamilyEvent {
  id               Int       @id @default(autoincrement())
  linkedCalendarId Int?
  source           String
  sourceEventId    String?
  title            String
  description      String?
  startAt          DateTime
  endAt            DateTime
  allDay           Boolean   @default(false)
  timezone         String
  colorHex         String?
  location         String?
  attendees        String?
  etag             String?
  visibility       String?
  deleted          Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  linkedCalendar LinkedCalendar? @relation(fields: [linkedCalendarId], references: [id], onDelete: SetNull)

  @@index([startAt, endAt])
}

model TaskRecurrence {
  id         Int      @id @default(autoincrement())
  frequency  String
  interval   Int      @default(1)
  byDay      String?
  byMonthDay String?
  until      DateTime?
  count      Int?
  createdAt  DateTime @default(now())
  tasks      Task[]
}

model Task {
  id           Int       @id @default(autoincrement())
  authorUserId Int?
  title        String
  description  String?
  dueAt        DateTime?
  priority     Int       @default(0)
  status       String    @default("OPEN")
  recurrenceId Int?
  labels       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  author      User?           @relation("TaskAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  recurrence  TaskRecurrence? @relation(fields: [recurrenceId], references: [id], onDelete: SetNull)
  assignments TaskAssignment[]
  statusChanges TaskStatusChange[]
}

model TaskAssignment {
  id           Int      @id @default(autoincrement())
  taskId       Int
  userId       Int
  status       String   @default("OPEN")
  progressNote String?
  completedAt  DateTime?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId, status])
}

model TaskStatusChange {
  id         Int      @id @default(autoincrement())
  taskId     Int
  fromStatus String
  toStatus   String
  changedBy  Int?
  note       String?
  createdAt  DateTime @default(now())

  task    Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changer User? @relation("TaskStatusChanger", fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
}

model Chore {
  id              Int              @id @default(autoincrement())
  title           String
  description     String?
  rotationType    String
  frequency       String
  interval        Int              @default(1)
  eligibleUserIds String
  weightMapJson   String?
  rewardPoints    Int              @default(0)
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  assignments ChoreAssignment[]
}

model ChoreAssignment {
  id            Int      @id @default(autoincrement())
  choreId       Int
  userId        Int?
  windowStart   DateTime
  windowEnd     DateTime
  state         String   @default("PENDING")
  rotationOrder Int?
  notes         String?
  completedAt   DateTime?
  verifiedById  Int?
  createdAt     DateTime @default(now())

  chore      Chore @relation(fields: [choreId], references: [id], onDelete: Cascade)
  assignee   User? @relation("ChoreAssignee", fields: [userId], references: [id], onDelete: SetNull)
  verifiedBy User? @relation("ChoreVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([state])
}

model GroceryList {
  id          Int      @id @default(autoincrement())
  ownerUserId Int?
  name        String
  store       String?
  presetKey   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User?        @relation("GroceryOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  items GroceryItem[]
}

model GroceryItem {
  id              Int      @id @default(autoincrement())
  listId          Int
  name            String
  category        String?
  quantity        Float    @default(1)
  unit            String?
  state           String   @default("NEEDED")
  assigneeUserId  Int?
  claimedByUserId Int?
  pantryItemKey   String?
  sortOrder       Int?
  notes           String?
  movedToInventoryAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  list      GroceryList @relation(fields: [listId], references: [id], onDelete: Cascade)
  assignee  User?       @relation("GroceryAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  claimedBy User?       @relation("GroceryClaimer", fields: [claimedByUserId], references: [id], onDelete: SetNull)
}

model InventoryItem {
  id                Int      @id @default(autoincrement())
  name              String
  category          String?
  quantity          Float    @default(1)
  unit              String?
  pantryItemKey     String?  @unique
  lowStockThreshold Float?
  notes             String?
  dateAdded         DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([name])
}

model Reminder {
  id              Int       @id @default(autoincrement())
  ownerUserId     Int
  targetType      String
  targetId        Int?
  title           String
  message         String?
  channelMask     Int        @default(1)
  leadTimeMinutes Int?       @default(0)
  quietHoursStart String?
  quietHoursEnd   String?
  enabled         Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  owner    User             @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  triggers ReminderTrigger[]
  notificationLogs NotificationLog[]
}

model ReminderTrigger {
  id            Int      @id @default(autoincrement())
  reminderId    Int
  channel       String
  nextFireAt    DateTime
  lastAttemptAt DateTime?
  lastStatus    String?
  retryCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([nextFireAt])
}

model Attachment {
  id               Int      @id @default(autoincrement())
  ownerUserId      Int?
  fileName         String
  filePath         String
  contentType      String?
  byteSize         Int?
  checksum         String?
  linkedEntityType String?
  linkedEntityId   Int?
  scanned          Boolean  @default(false)
  createdAt        DateTime @default(now())

  owner User? @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  actorUserId Int?
  actionType  String
  entityType  String?
  entityId    Int?
  payload     String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
}

model SearchIndex {
  entityType String
  entityId   Int
  content    String

  @@id([entityType, entityId])
  @@index([content])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NotificationLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  reminderId  Int?
  channel     String
  title       String
  body        String?
  status      String   @default("PENDING")
  errorDetail String?
  sentAt      DateTime?
  createdAt   DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminder Reminder? @relation(fields: [reminderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status])
}

model HouseholdSetting {
  key       String   @id
  value     String   // JSON-serialized value
  updatedAt DateTime @updatedAt
}

model Recipe {
  id              Int      @id @default(autoincrement())
  title           String
  description     String?
  servings        Int      @default(1)
  prepMinutes     Int?
  cookMinutes     Int?
  sourceUrl       String?
  ingredientsJson String   @default("[]")
  createdByUserId Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy User            @relation("RecipeAuthor", fields: [createdByUserId], references: [id], onDelete: Cascade)
  entries   MealPlanEntry[]
}

model MealPlan {
  id              Int      @id @default(autoincrement())
  title           String?
  weekStart       DateTime
  createdByUserId Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy User            @relation("MealPlanAuthor", fields: [createdByUserId], references: [id], onDelete: Cascade)
  entries   MealPlanEntry[]
}

model MealPlanEntry {
  id         Int      @id @default(autoincrement())
  mealPlanId Int
  recipeId   Int?
  title      String
  mealType   String
  dayOffset  Int
  servings   Int      @default(1)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipe   Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)
}
