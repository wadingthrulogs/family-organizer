# Family Organizer MCP — env template

# --- Required ---
ORGANIZER_BASE_URL=http://localhost:3000
ORGANIZER_USERNAME=claude-bot
ORGANIZER_PASSWORD=replace-me

# --- Optional ---
# stdio (default) for Claude Code locally; http for remote / Tailscale.
MCP_TRANSPORT=stdio

# Only used when MCP_TRANSPORT=http
MCP_HTTP_PORT=3100
MCP_HTTP_HOST=127.0.0.1
# Strongly recommended in HTTP mode. The server returns 401 for any request
# without a matching `Authorization: Bearer <value>` header.
MCP_HTTP_BEARER=
